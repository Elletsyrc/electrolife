<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings &amp; Goals"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/gray_900"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Electricity Rate (PHP per kWh)"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_electricity_rate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/bg_white_rounded"
            android:layout_marginBottom="16dp"
            android:hint="12.0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Budget Goal ($)"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_budget_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/bg_white_rounded"
            android:layout_marginBottom="16dp"
            android:hint="100.00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Energy Goal (kWh)"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_kwh_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/bg_white_rounded"
            android:layout_marginBottom="24dp"
            android:hint="300" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Save &amp; Apply Configuration"
            android:padding="16dp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_settings" />

    </LinearLayout>
</ScrollView>